LMSERV_LISTEN_ADDR=:8080
LMSERV_SHUTDOWN_TIMEOUT=15s

DOCKER_HOST=unix:///var/run/docker.sock

LMSERV_TOTAL_VRAM_MB=10240
LMSERV_TEXT_CLASS_BUDGET_MB=4096
LMSERV_IMAGE_CLASS_BUDGET_MB=6144

LMSERV_TEXT_QUEUE_CAPACITY=64
LMSERV_IMAGE_QUEUE_CAPACITY=16
LMSERV_TEXT_WORKERS=2
LMSERV_IMAGE_WORKERS=1

LMSERV_SCHEDULER_POLL_INTERVAL=150ms
LMSERV_MAINTENANCE_INTERVAL=20s
LMSERV_CONTAINER_READY_INTERVAL=500ms

LMSERV_TEXT_IMAGE=registry.local/lmserv/llama-cpp-rocm:latest
LMSERV_TEXT_CONTAINER_PORT=8080
LMSERV_TEXT_TARGET_PATH=/v1/chat/completions
LMSERV_TEXT_HEALTH_PATH=/health
LMSERV_TEXT_VRAM_MB=3072
LMSERV_TEXT_MAX_CONTAINERS=2
LMSERV_TEXT_START_TIMEOUT=90s
LMSERV_TEXT_IDLE_PAUSE_AFTER=90s
LMSERV_TEXT_IDLE_DESTROY_AFTER=10m

LMSERV_IMAGE_IMAGE=registry.local/lmserv/vllm-rocm:latest
LMSERV_IMAGE_CONTAINER_PORT=8000
LMSERV_IMAGE_TARGET_PATH=/v1/chat/completions
LMSERV_IMAGE_HEALTH_PATH=/health
LMSERV_IMAGE_VRAM_MB=6144
LMSERV_IMAGE_MAX_CONTAINERS=1
LMSERV_IMAGE_START_TIMEOUT=120s
LMSERV_IMAGE_IDLE_PAUSE_AFTER=2m
LMSERV_IMAGE_IDLE_DESTROY_AFTER=12m
